exports[`print HTML golden snapshots eu-schengen on us-letter, cutLines=false 1`] = `
"<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  @page {
    size: 8.5in 11in;
    margin: 0;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 8.5in;
    height: 11in;
    background: #ffffff;
  }
  .sheet {
    position: relative;
    width: 8.5in;
    height: 11in;
  }
  .tile { position: absolute; }
  .guide {
    position: absolute;
    /* Darker + thicker so users can actually see where to cut. */
    border-top: 1pt solid #0A0A0A;
    border-left: 1pt solid #0A0A0A;
  }
</style>
</head>
<body>
